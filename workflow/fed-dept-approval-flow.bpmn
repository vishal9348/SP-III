<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://bpmn.io/schema/bpmn">

  <process id="fed-dept-approval-flow" name="FED Department Approval Flow" isExecutable="true" camunda:historyTimeToLive="30">

    <startEvent id="start-event" name="Form Submitted" />

    <sequenceFlow id="flow1" sourceRef="start-event" targetRef="rmaker-task" />

    <!-- Level 1: Rmaker Approval -->
    <userTask id="rmaker-task" name="Rmaker Approval" camunda:assignee="rmaker" camunda:priority="50">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="approved" label="Approve?" type="boolean" />
          <camunda:formField id="rmakerComments" label="Comments" type="string" />
        </camunda:formData>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flow2" sourceRef="rmaker-task" targetRef="rchecker-task" />

    <!-- Level 2: Rchecker Approval -->
    <userTask id="rchecker-task" name="Rchecker Approval" camunda:assignee="rchecker" camunda:priority="50">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="approved" label="Approve?" type="boolean" />
          <camunda:formField id="rcheckerComments" label="Comments" type="string" />
        </camunda:formData>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flow3" sourceRef="rchecker-task" targetRef="comaker-task" />

    <!-- Level 3: Comaker Approval -->
    <userTask id="comaker-task" name="Comaker Approval" camunda:assignee="comaker" camunda:priority="50">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="approved" label="Approve?" type="boolean" />
          <camunda:formField id="comakerComments" label="Comments" type="string" />
        </camunda:formData>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flow4" sourceRef="comaker-task" targetRef="cochecker-task" />

    <!-- Level 4: Cochecker Approval -->
    <userTask id="cochecker-task" name="Cochecker Approval" camunda:assignee="cochecker" camunda:priority="50">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="approved" label="Approve?" type="boolean" />
          <camunda:formField id="cocheckerComments" label="Comments" type="string" />
        </camunda:formData>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flow5" sourceRef="cochecker-task" targetRef="end-event" />

    <endEvent id="end-event" name="Form Fully Approved" />

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_fed">
    <bpmndi:BPMNPlane id="BPMNPlane_fed" bpmnElement="fed-dept-approval-flow">

      <bpmndi:BPMNShape id="start-event-di" bpmnElement="start-event">
        <dc:Bounds x="80" y="100" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="70" y="140" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="rmaker-task-di" bpmnElement="rmaker-task">
        <dc:Bounds x="180" y="80" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="195" y="115" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="rchecker-task-di" bpmnElement="rchecker-task">
        <dc:Bounds x="340" y="80" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="350" y="115" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="comaker-task-di" bpmnElement="comaker-task">
        <dc:Bounds x="500" y="80" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="515" y="115" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="cochecker-task-di" bpmnElement="cochecker-task">
        <dc:Bounds x="660" y="80" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="670" y="115" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="end-event-di" bpmnElement="end-event">
        <dc:Bounds x="830" y="100" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="820" y="140" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="flow1-di" bpmnElement="flow1">
        <di:waypoint x="116" y="118" />
        <di:waypoint x="180" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow2-di" bpmnElement="flow2">
        <di:waypoint x="280" y="120" />
        <di:waypoint x="340" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow3-di" bpmnElement="flow3">
        <di:waypoint x="440" y="120" />
        <di:waypoint x="500" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow4-di" bpmnElement="flow4">
        <di:waypoint x="600" y="120" />
        <di:waypoint x="660" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow5-di" bpmnElement="flow5">
        <di:waypoint x="760" y="120" />
        <di:waypoint x="830" y="118" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>